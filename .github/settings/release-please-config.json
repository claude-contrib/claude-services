{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "simple",
  "packages": {
    ".": {
      "release-type": "simple",
      "extra-files": [
        {
          "type": "json",
          "path": ".claude-plugin/marketplace.json",
          "jsonpath": "$.metadata.version"
        }
      ]
    },
    "plugins/thinking": {
      "release-type": "simple",
      "component": "thinking",
      "extra-files": [
        {
          "type": "json",
          "path": ".claude-plugin/plugin.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "/.claude-plugin/marketplace.json",
          "jsonpath": "$.plugins[?(@.name=='thinking')].version"
        }
      ]
    },
    "plugins/filesystem": {
      "release-type": "simple",
      "component": "filesystem",
      "extra-files": [
        {
          "type": "json",
          "path": ".claude-plugin/plugin.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "/.claude-plugin/marketplace.json",
          "jsonpath": "$.plugins[?(@.name=='filesystem')].version"
        }
      ]
    },
    "plugins/playwright": {
      "release-type": "simple",
      "component": "playwright",
      "extra-files": [
        {
          "type": "json",
          "path": ".claude-plugin/plugin.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "/.claude-plugin/marketplace.json",
          "jsonpath": "$.plugins[?(@.name=='playwright')].version"
        }
      ]
    }
  }
}
